// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bundle {
  id              String       @id @default(cuid())
  shop            String
  title           String
  description     String?
  type            String // FIXED | MIX_MATCH
  status          String       @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  pricingType     String       @default("PERCENT_OFF") // FIXED_PRICE | PERCENT_OFF | AMOUNT_OFF
  pricingValue    Float        @default(0)
  // FIXED bundles: the Shopify parent product we create for the bundle
  shopifyProductId String?
  // Storefront "what's inside" widget appearance (FIXED bundles only)
  widgetStyle     String       @default("numbered") // numbered | grid | minimal
  widgetHeading   String       @default("What's inside")
  accentColor     String       @default("#1a1a1a")
  showPrices      Boolean      @default(false)
  // Plain text + {{sku}}/{{vendor}}/{{type}}/{{barcode}}/{{weight}}/{{metafield:ns.key}}
  // placeholders, resolved per-item and rendered under each product's title
  itemSubtextTemplate String   @default("")
  showSubtextOnGifts  Boolean  @default(true)
  items           BundleItem[]
  rule            BundleRule?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([shop, status])
}

model BundleItem {
  id               String  @id @default(cuid())
  bundleId         String
  bundle           Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId        String // Shopify product GID
  variantId        String? // Shopify variant GID (null = any variant)
  productTitle     String
  productImageUrl  String?
  quantity         Int     @default(1)
  isGift           Boolean @default(false)
  position         Int     @default(0)
}

// Mix & match rules: which products are eligible and the discount tiers
model BundleRule {
  id            String @id @default(cuid())
  bundleId      String @unique
  bundle        Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  minItems      Int    @default(2)
  maxItems      Int?
  // JSON: [{ "quantity": 3, "discount": 10 }, { "quantity": 5, "discount": 15 }]
  discountTiers String @default("[]")
  // JSON array of eligible collection GIDs
  collectionIds String @default("[]")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
